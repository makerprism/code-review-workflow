{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://makerprism.github.io/code-review-workflow/review-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "standards",
    "failed_required_ids",
    "summary"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "failed_required_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "standards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "reason",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "not_applicable"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "suggested_fix": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "file",
                "line",
                "note"
              ],
              "properties": {
                "file": {
                  "type": "string",
                  "minLength": 1
                },
                "line": {
                  "type": "integer",
                  "minimum": 1
                },
                "note": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
